# PathFinder AI — Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Get your free API key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# REQUIRED: Flask secret key — change this to any long random string
SECRET_KEY=change_this_to_a_long_random_secret_string_min_32_chars

# App environment
FLASK_ENV=development
FLASK_DEBUG=1

# Database — SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite:///pathfinder.db

# Optional: For production PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/pathfinder_db
